{
  "name": "@storycarouselkit/core",
  "version": "0.1.4",
  "description": "Framework-agnostic core logic for story carousel component",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm clean && pnpm build && pnpm test"
  },
  "keywords": [
    "stories",
    "carousel",
    "typescript",
    "core"
  ],
  "author": "StoryKit Team",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/delpin/StoryCarouselKit.git",
    "directory": "packages/native"
  },
  "homepage": "https://delpin.github.io/StoryCarouselKit/",
  "bugs": {
    "url": "https://github.com/delpin/StoryCarouselKit/issues"
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "eslint": "^9.9.0",
    "prettier": "^3.3.0",
    "semver": "^7.6.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
