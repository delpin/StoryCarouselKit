{
  "name": "@storykit/core",
  "version": "0.1.0",
  "description": "Framework-agnostic core logic for story carousel component",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "lint": "eslint src --ext .ts,.tsx",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm clean && pnpm build && pnpm test"
  },
  "keywords": [
    "stories",
    "carousel",
    "typescript",
    "core"
  ],
  "author": "StoryKit Team",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/storykit/story-carousel-monorepo.git",
    "directory": "packages/native"
  },
  "homepage": "https://storykit.dev",
  "bugs": {
    "url": "https://github.com/storykit/story-carousel-monorepo/issues"
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "eslint": "^8.0.0",
    "semver": "^7.6.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}