{
  "name": "@storycarouselkit/react",
  "version": "0.1.0",
  "description": "React component for Instagram-style story carousels with autoplay, progress indicators, and TypeScript support",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm clean && pnpm build && pnpm test"
  },
  "keywords": [
    "story-carousel",
    "story-reel",
    "story-viewer",
    "story-player",
    "react",
    "react-stories",
    "social-stories",
    "instagram-stories",
    "carousel",
    "stories",
    "carousel-component",
    "component-library",
    "typescript",
    "progress-indicators",
    "auto-play",
    "story-component",
    "story-feed",
    "ui-components"
  ],
  "author": "StoryCarouselKit Team",
  "homepage": "https://delpin.github.io/StoryCarouselKit/",
  "bugs": {
    "url": "https://github.com/delpin/StoryCarouselKit/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/delpin/StoryCarouselKit.git",
    "directory": "packages/react"
  },
  "files": [
    "dist",
    "README.md",
    "README.ru.md",
    "README.cn.md",
    "package.json"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "license": "MIT",
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "dependencies": {
    "@storycarouselkit/core": "workspace:*"
  },
  "devDependencies": {
    "@testing-library/react": "^14.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "eslint": "^9.9.0",
    "happy-dom": "^20.8.3",
    "jsdom": "^28.1.0",
    "prettier": "^3.3.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}